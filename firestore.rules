rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isAuthenticated()
        && get(
          /databases/$(database)/documents/usuarios/$(request.auth.uid)
        ).data.role == 'super_admin';
    }

    match /usuarios/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /produtos/{documentId} {
      allow read, write: if isAuthenticated();
    }

    match /vendas/{documentId} {
      allow read, write: if isAuthenticated();
    }

    match /entradas/{documentId} {
      allow read, write: if isAuthenticated();
    }

    match /fiados/{documentId} {
      allow read, write: if isAuthenticated();
    }

    match /historico/{documentId} {
      allow read, write: if isAuthenticated();
    }

    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}